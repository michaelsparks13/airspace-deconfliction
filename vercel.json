{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"buildCommand": "npm run fetch-tiles && npm run build",
	"outputDirectory": "dist",
	"installCommand": "npm install",
	"framework": null,
	"headers": [
		{
			"source": "/tiles/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/assets/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		}
	]
}
